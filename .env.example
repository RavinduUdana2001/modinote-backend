PORT=5000
NODE_ENV=development
JWT_SECRET=replace_with_your_jwt_secret
CORS_ORIGIN=http://localhost:5173
SARVAM_API_KEY=replace_with_your_sarvam_key
SARVAM_BASE_URL=https://api.sarvam.ai
SARVAM_TIMEOUT_MS=120000
SARVAM_BATCH_POLL_INTERVAL_MS=3000
SARVAM_BATCH_MAX_WAIT_MS=900000
SARVAM_REST_MAX_DURATION_SECONDS=30
SARVAM_DEBUG=true
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_MODE=translate
MAX_VOICE_FILE_MB=150
